                        </label>
                    </div>
                </div>

                <div class="manage-section">
                    <h3>当前文件</h3>
                    <div
                        id="current-file-path"
                        style="font-size:0.8125rem;opacity:0.6;word-break:break-all"
                    >
                    </div>
                    <button
                        class="btn-icon"
                        onclick="openFileLocation()"
                        title="在文件管理器中定位"
                        style="margin-top:6px;font-size:0.8125rem;gap:4px"
                    >
                        <svg
                            width="13"
                            height="13"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z"
                            ></path></svg
                        >
                        在文件管理器中定位
                    </button>
                </div>

                <div class="manage-section">
                    <h3>目录管理</h3>
                    <div id="dir-list-drop-zone">
                        <div id="dir-list-manage"></div>
                    </div>
                    <button
                        class="btn-primary"
                        onclick="addDirectory()"
                        style="margin-top:8px;padding:4px 12px;font-size:0.8125rem;border:none;border-radius:6px;cursor:pointer"
                        >+ 添加目录</button
                    >
                </div>

                <div
                    class="manage-section"
                    style="font-size:0.75rem;opacity:0.35;display:flex;flex-direction:column;gap:4px"
                >
                    <span>Excalidraw v{excalidrawVersion}</span>
                    <a
                        href="https://github.com/yhui02/YooExcalidraw"
                        target="_blank"
                        rel="noopener noreferrer"
                        style="color:inherit;text-decoration:underline"
                        >GitHub 项目地址</a
                    >
                </div>

                </div>

                <div class="manage-dialog-footer">
                <div class="manage-footer">
                    <button
                        class="manage-close-btn"
