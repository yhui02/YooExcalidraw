---
import '@/styles/global.css';
---
<!doctype html>
<html lang="zh-CN" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>登录 - YooExcalidraw</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    html, body { height: 100%; margin: 0; }
    body {
      font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
      background:
        radial-gradient(at 20% 20%, hsla(228,80%,70%,0.18) 0px, transparent 50%),
        radial-gradient(at 80% 30%, hsla(280,80%,70%,0.16) 0px, transparent 50%),
        radial-gradient(at 60% 90%, hsla(180,80%,70%,0.14) 0px, transparent 50%),
        #f8fafc;
    }
    .auth-wrap {
      min-height: 100vh; display: flex;
      align-items: center; justify-content: center;
      padding: 1.5rem;
    }
    .auth-card {
      width: 100%; max-width: 420px;
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.6);
      border-radius: 20px;
      padding: 2.5rem 2.25rem;
      box-shadow:
        0 1px 0 rgba(255,255,255,0.6) inset,
        0 20px 50px -20px rgba(15,23,42,0.15),
        0 4px 12px -4px rgba(15,23,42,0.08);
    }
    .brand {
      display: flex; align-items: center; justify-content: center;
      gap: 12px; margin-bottom: 1.5rem;
    }
    .brand-logo {
      width: 44px; height: 44px;
      border-radius: 12px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      display: flex; align-items: center; justify-content: center;
      color: white; font-weight: 800; font-size: 1.25rem;
      box-shadow: 0 8px 20px -8px rgba(99,102,241,0.55);
    }
    .brand-text {
      font-size: 1.375rem; font-weight: 700;
      color: #0f172a; letter-spacing: -0.02em;
    }
    .auth-subtitle {
      text-align: center; color: #64748b;
      font-size: 0.875rem; margin-bottom: 1.75rem;
    }
    .field { margin-bottom: 1rem; }
    .field label {
      display: block; font-size: 0.8125rem;
      color: #334155; margin-bottom: 0.375rem;
      font-weight: 500;
    }
    .field input {
      width: 100%; box-sizing: border-box;
      padding: 0.625rem 0.875rem;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      font-size: 0.9375rem;
      background: white;
      transition: border-color 0.15s, box-shadow 0.15s;
      outline: none;
      color: #0f172a;
    }
    .field input::placeholder { color: #cbd5e1; }
    .field input:focus {
      border-color: #6366f1;
      box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    }
    .auth-btn {
      width: 100%; padding: 0.75rem 1rem;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: white; border: none; border-radius: 10px;
      font-size: 0.9375rem; font-weight: 600;
      cursor: pointer; margin-top: 0.5rem;
      transition: transform 0.1s, box-shadow 0.15s;
      box-shadow: 0 8px 20px -8px rgba(99,102,241,0.6);
    }
    .auth-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 24px -8px rgba(99,102,241,0.7);
    }
    .auth-btn:active { transform: translateY(0); }
    .auth-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .auth-switch {
      text-align: center; margin-top: 1.25rem;
      font-size: 0.8125rem; color: #64748b;
    }
    .auth-switch a {
      color: #6366f1; text-decoration: none;
      font-weight: 600; margin-left: 0.25rem;
    }
    .auth-switch a:hover { text-decoration: underline; }
    .auth-error {
      min-height: 1.25rem;
      color: #ef4444; font-size: 0.8125rem;
      text-align: center; margin-top: 0.75rem;
    }
    .auth-tip {
      margin-top: 1.5rem; padding: 0.75rem 1rem;
      background: rgba(99,102,241,0.06);
      border: 1px solid rgba(99,102,241,0.15);
      border-radius: 10px;
      font-size: 0.75rem; color: #475569;
      line-height: 1.5;
    }
    .auth-tip code {
      background: rgba(15,23,42,0.06);
      padding: 1px 6px; border-radius: 4px;
      font-family: ui-monospace, SFMono-Regular, monospace;
      color: #0f172a;
    }
  </style>
</head>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="brand">
        <div class="brand-logo">Y</div>
        <div class="brand-text">YooExcalidraw</div>
      </div>

      <div id="login-view">
        <p class="auth-subtitle">登录到你的画板工作台</p>
        <div class="field">
          <label for="login-username">用户名</label>
          <input type="text" id="login-username" placeholder="请输入用户名" autocomplete="username" />
        </div>
        <div class="field">
          <label for="login-password">密码</label>
          <input type="password" id="login-password" placeholder="请输入密码" autocomplete="current-password" />
        </div>
        <button class="auth-btn" id="login-btn">登 录</button>
        <div id="login-error" class="auth-error"></div>
        <div class="auth-switch">
          还没有账号？<a href="#" id="switch-to-register">立即注册</a>
        </div>
        <div class="auth-tip">
          预设管理账号：<code>admin</code> / <code>admin123</code>
        </div>
      </div>

      <div id="register-view" style="display:none">
        <p class="auth-subtitle">创建一个新账号</p>
        <div class="field">
          <label for="reg-username">用户名</label>
          <input type="text" id="reg-username" placeholder="3-20 个字符" autocomplete="username" />
        </div>
        <div class="field">
          <label for="reg-password">密码</label>
          <input type="password" id="reg-password" placeholder="至少 6 个字符" autocomplete="new-password" />
        </div>
        <button class="auth-btn" id="register-btn">注 册</button>
        <div id="reg-error" class="auth-error"></div>
        <div class="auth-switch">
          已有账号？<a href="#" id="switch-to-login">返回登录</a>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const API = '/api/auth';

    function showError(id, msg) {
      document.getElementById(id).textContent = msg;
    }
    function clearError(id) {
      document.getElementById(id).textContent = '';
    }

    document.getElementById('switch-to-register').addEventListener('click', function(e) {
      e.preventDefault();
      document.getElementById('login-view').style.display = 'none';
      document.getElementById('register-view').style.display = '';
      clearError('login-error');
    });

    document.getElementById('switch-to-login').addEventListener('click', function(e) {
      e.preventDefault();
      document.getElementById('register-view').style.display = 'none';
      document.getElementById('login-view').style.display = '';
      clearError('reg-error');
    });

    async function doLogin() {
      const btn = document.getElementById('login-btn');
      const username = document.getElementById('login-username').value.trim();
      const password = document.getElementById('login-password').value;
      if (!username || !password) { showError('login-error', '请填写用户名和密码'); return; }
      btn.disabled = true;
      try {
        const res = await fetch(API + '/login', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password }),
        });
        const data = await res.json();
        if (data.code === 0) {
          localStorage.setItem('excalidraw_token', data.data.token);
          localStorage.setItem('excalidraw_username', data.data.username);
          window.location.href = '/';
        } else {
          showError('login-error', data.msg || '登录失败');
          btn.disabled = false;
        }
      } catch (e) {
        showError('login-error', '网络错误');
        btn.disabled = false;
      }
    }

    async function doRegister() {
      const btn = document.getElementById('register-btn');
      const username = document.getElementById('reg-username').value.trim();
      const password = document.getElementById('reg-password').value;
      if (!username || !password) { showError('reg-error', '请填写用户名和密码'); return; }
      if (password.length < 6) { showError('reg-error', '密码至少 6 个字符'); return; }
      btn.disabled = true;
      try {
        const res = await fetch(API + '/register', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password }),
        });
        const data = await res.json();
        if (data.code === 0) {
          localStorage.setItem('excalidraw_token', data.data.token);
          localStorage.setItem('excalidraw_username', data.data.username);
          window.location.href = '/';
        } else {
          showError('reg-error', data.msg || '注册失败');
          btn.disabled = false;
        }
      } catch (e) {
        showError('reg-error', '网络错误');
        btn.disabled = false;
      }
    }

    document.getElementById('login-btn').addEventListener('click', doLogin);
    document.getElementById('register-btn').addEventListener('click', doRegister);

    function bindEnter(formId, fn) {
      ['login-username','login-password','reg-username','reg-password'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('keydown', function(e) {
          if (e.key === 'Enter') {
            if (id.startsWith('login')) doLogin();
            else doRegister();
          }
        });
      });
    }
    bindEnter();

    if (localStorage.getItem('excalidraw_token')) {
      window.location.href = '/';
    }
  </script>
</body>
</html>
